---
import '../styles/global.css';
import Header from '../components/Header.astro';
import CommandPalette from '../components/CommandPalette.astro';
import LiquidEther from '../components/LiquidEther.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const appsCollection = await getCollection('apps');
const catalogApps = appsCollection.map((a) => ({
  name: a.data.name,
  slug: a.data.slug,
  tagline: a.data.tagline,
  icon: a.data.icon,
}));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0f1218" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        // Dark is the default; a user's explicit choice is remembered.
        var stored = localStorage.getItem('theme');
        var theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <LiquidEther />
    <div class="app-shell">
      <Header />
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span class="brand">Desktop app marketplace</span>
        <p>A small, curated store for native Mac apps built to be driven — by you, or by your agent.</p>
        <p class="footer-support">Supported by <a href="https://kriyanative.com" target="_blank" rel="noopener">kriyanative.com</a></p>
      </footer>
    </div>
    <CommandPalette apps={catalogApps} />
    <script>
      const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
      let themeTransitionInFlight = false;
      toggle?.addEventListener('click', (e) => {
        if (themeTransitionInFlight) return;
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'light' ? 'dark' : 'light';
        const rect = toggle.getBoundingClientRect();
        document.documentElement.style.setProperty('--theme-toggle-x', `${rect.left + rect.width / 2}px`);
        document.documentElement.style.setProperty('--theme-toggle-y', `${rect.top + rect.height / 2}px`);

        const apply = () => {
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        };

        // @ts-ignore - startViewTransition is not yet in the TS DOM lib everywhere
        if (document.startViewTransition && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          themeTransitionInFlight = true;
          // @ts-ignore
          const transition = document.startViewTransition(apply);
          transition.finished.catch(() => {}).finally(() => {
            themeTransitionInFlight = false;
          });
        } else {
          apply();
        }
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el, i) => {
        (el as HTMLElement).style.setProperty('--reveal-index', String(i % 6));
        io.observe(el);
      });
    </script>
    <script>
      // Pull live release info from GitHub so the site always reflects the
      // *latest* release — total downloads, version, size, checksum — without
      // anyone editing the site per release. One API call per repo.
      (function () {
        const repos = new Set<string>();
        document.querySelectorAll('[data-repo]').forEach((el) => {
          const r = el.getAttribute('data-repo');
          if (r) repos.add(r);
        });
        repos.forEach((repo) => {
          fetch(`https://api.github.com/repos/${repo}/releases`)
            .then((r) => (r.ok ? r.json() : null))
            .then((releases) => {
              if (!Array.isArray(releases) || !releases.length) return;
              const total = releases.reduce(
                (s: number, rel: any) => s + (rel.assets || []).reduce((a: number, x: any) => a + (x.download_count || 0), 0),
                0
              );
              const latest = releases.find((rel: any) => !rel.draft && !rel.prerelease) || releases[0];
              const dmg = (latest.assets || []).find((a: any) => /\.dmg$/i.test(a.name)) || (latest.assets || [])[0];
              const shaMatch = latest.body ? String(latest.body).match(/[a-f0-9]{64}/i) : null;

              const sel = (attr: string) =>
                document.querySelectorAll<HTMLElement>(`[${attr}][data-repo="${repo}"]`);

              sel('data-dl-count').forEach((el) => { el.textContent = total.toLocaleString(); });
              if (latest.tag_name) sel('data-latest-version').forEach((el) => { el.textContent = latest.tag_name; });
              if (dmg && dmg.size) {
                const mb = (dmg.size / (1024 * 1024)).toFixed(1) + ' MB';
                sel('data-latest-size').forEach((el) => { el.textContent = mb; });
              }
              if (shaMatch) {
                sel('data-latest-sha').forEach((el) => {
                  el.textContent = shaMatch[0];
                  const box = el.closest('[data-checksum]') as HTMLElement | null;
                  if (box) box.hidden = false;
                });
              }
            })
            .catch(() => {});
        });
      })();
    </script>
  </body>
</html>
