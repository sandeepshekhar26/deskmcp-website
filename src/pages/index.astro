---
import Base from '../layouts/Base.astro';
import ElectricBorder from '../components/ElectricBorder.astro';
import { getCollection } from 'astro:content';

const apps = await getCollection('apps');
const auk = apps.find((a) => a.data.slug === 'auk')!.data;
const repoPath = auk.repo.replace('https://github.com/', '');
---
<Base
  title="Desktop app marketplace — native Mac apps built to be driven"
  description="A small, curated store for native macOS apps that ship as a real .dmg and speak MCP — so you, or your AI agent, can drive them. No web wrappers, no accounts, no lock-in."
>
  <section class="marketplace-hero">
    <div class="marketplace-hero-inner">
      <p class="eyebrow boot-item boot-1">Desktop app marketplace</p>
      <h1 class="boot-item boot-2">Native Mac apps,<br>built to be driven.</h1>
      <p class="lede boot-item boot-2">
        A small, curated store for native macOS tools that ship as a real <code>.dmg</code> and speak MCP —
        so you, or your AI agent, can drive them. No web wrappers, no accounts, no lock-in.
      </p>
      <div class="hero-badges boot-item boot-3">
        <span class="chip chip-signal">MCP-native</span>
        <span class="chip">Real .dmg downloads</span>
        <span class="chip">No account wall</span>
        <span class="chip">macOS</span>
      </div>
      <div class="hero-actions boot-item boot-3">
        <a class="btn btn-brass" href="#catalog">Browse the catalog &darr;</a>
      </div>
    </div>
  </section>

  <section id="catalog" class="catalog" style="padding-top:clamp(2.5rem,5vw,3.5rem)">
    <div class="section-head" data-reveal>
      <h2>The catalog</h2>
      <p class="catalog-count">1 app live today &mdash; the shelf is filling up</p>
    </div>

    <div class="featured-wrap" data-reveal>
      <ElectricBorder color="#57c2b8" speed={1} chaos={0.14} borderRadius={22}>
        <a class="featured-card" href={`/apps/${auk.slug}`}>
          <div class="featured-media">
            <img src={`/screenshots/${auk.slug}/dark-theme.jpg`} alt="AUK — request, response and assertions" loading="eager" />
          </div>
          <div class="featured-body">
            <span class="tile-badge">Featured</span>
            <div class="featured-id">
              <img class="featured-icon" src={auk.icon} alt="" />
              <div>
                <h3>{auk.name}</h3>
                <p class="featured-tag">{auk.tagline}</p>
              </div>
            </div>
            <p class="featured-desc">{auk.hero.subhead}</p>
            <div class="featured-chips">
              <span class="chip">API Client</span>
              <span class="chip">k6 load testing</span>
              <span class="chip">Embedded MCP</span>
              <span class="chip">Git-native</span>
            </div>
            <div class="featured-foot">
              <span class="featured-dl">
                <span class="dot dot-live"></span>
                <span data-dl-count data-repo={repoPath} data-release-tag={auk.releaseTag}>&mdash;</span> downloads
              </span>
              <span class="featured-cta">View app &rarr;</span>
            </div>
          </div>
        </a>
      </ElectricBorder>
    </div>

    <div class="coming-soon-row" data-reveal-group>
      <div class="tile tile-ghost" data-reveal><span class="ghost-plus">+</span><span class="tile-name">Coming soon</span></div>
      <div class="tile tile-ghost" data-reveal><span class="ghost-plus">+</span><span class="tile-name">Coming soon</span></div>
      <div class="tile tile-ghost" data-reveal><span class="ghost-plus">+</span><span class="tile-name">Coming soon</span></div>
    </div>
  </section>
</Base>
