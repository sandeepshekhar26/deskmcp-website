---
// Vanilla port of the React Bits <ElectricBorder /> — animated electric outline
// on a <canvas>, framework-free so it stays in the lean Astro static site.
interface Props {
  color?: string;
  speed?: number;
  chaos?: number;
  borderRadius?: number;
  class?: string;
}
const { color = '#57c2b8', speed = 1, chaos = 0.14, borderRadius = 24, class: className = '' } = Astro.props;
---
<div
  class:list={['electric-border', className]}
  style={`--electric-border-color:${color};border-radius:${borderRadius}px`}
  data-eb-speed={speed}
  data-eb-chaos={chaos}
  data-eb-radius={borderRadius}
>
  <div class="eb-canvas-container"><canvas class="eb-canvas"></canvas></div>
  <div class="eb-layers">
    <div class="eb-glow-1"></div>
    <div class="eb-glow-2"></div>
    <div class="eb-background-glow"></div>
  </div>
  <div class="eb-content"><slot /></div>
</div>

<script>
  function initElectricBorder(el: HTMLElement) {
    if ((el as any).__ebInit) return;
    const canvas = el.querySelector<HTMLCanvasElement>('.eb-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    (el as any).__ebInit = true;

    const speed = parseFloat(el.dataset.ebSpeed || '1');
    const chaos = parseFloat(el.dataset.ebChaos || '0.14');
    const borderRadius = parseFloat(el.dataset.ebRadius || '24');

    const octaves = 10;
    const lacunarity = 1.6;
    const gain = 0.7;
    const amplitude = chaos;
    const frequency = 10;
    const baseFlatness = 0;
    const displacement = 60;
    const borderOffset = 60;

    const random = (x: number) => (Math.sin(x * 12.9898) * 43758.5453) % 1;
    const noise2D = (x: number, y: number) => {
      const i = Math.floor(x), j = Math.floor(y), fx = x - i, fy = y - j;
      const a = random(i + j * 57), b = random(i + 1 + j * 57);
      const c = random(i + (j + 1) * 57), d = random(i + 1 + (j + 1) * 57);
      const ux = fx * fx * (3 - 2 * fx), uy = fy * fy * (3 - 2 * fy);
      return a * (1 - ux) * (1 - uy) + b * ux * (1 - uy) + c * (1 - ux) * uy + d * ux * uy;
    };
    const octavedNoise = (x: number, seed: number, time: number) => {
      let y = 0, amp = amplitude, freq = frequency;
      for (let i = 0; i < octaves; i++) {
        let oa = amp;
        if (i === 0) oa *= baseFlatness;
        y += oa * noise2D(freq * x + seed * 100, time * freq * 0.3);
        freq *= lacunarity;
        amp *= gain;
      }
      return y;
    };
    const corner = (cx: number, cy: number, r: number, sa: number, arc: number, p: number) => {
      const a = sa + p * arc;
      return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) };
    };
    const rrPoint = (t: number, left: number, top: number, w: number, h: number, r: number) => {
      const sw = w - 2 * r, sh = h - 2 * r, ca = (Math.PI * r) / 2;
      const total = 2 * sw + 2 * sh + 4 * ca;
      const d = t * total;
      let acc = 0;
      if (d <= acc + sw) { const p = (d - acc) / sw; return { x: left + r + p * sw, y: top }; }
      acc += sw;
      if (d <= acc + ca) { const p = (d - acc) / ca; return corner(left + w - r, top + r, r, -Math.PI / 2, Math.PI / 2, p); }
      acc += ca;
      if (d <= acc + sh) { const p = (d - acc) / sh; return { x: left + w, y: top + r + p * sh }; }
      acc += sh;
      if (d <= acc + ca) { const p = (d - acc) / ca; return corner(left + w - r, top + h - r, r, 0, Math.PI / 2, p); }
      acc += ca;
      if (d <= acc + sw) { const p = (d - acc) / sw; return { x: left + w - r - p * sw, y: top + h }; }
      acc += sw;
      if (d <= acc + ca) { const p = (d - acc) / ca; return corner(left + r, top + h - r, r, Math.PI / 2, Math.PI / 2, p); }
      acc += ca;
      if (d <= acc + sh) { const p = (d - acc) / sh; return { x: left, y: top + h - r - p * sh }; }
      acc += sh;
      const p = (d - acc) / ca;
      return corner(left + r, top + r, r, Math.PI, Math.PI / 2, p);
    };

    let width = 0, height = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    const size = () => {
      const rect = el.getBoundingClientRect();
      if (rect.width === 0) return;
      width = rect.width + borderOffset * 2;
      height = rect.height + borderOffset * 2;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
    };
    size();

    const color = getComputedStyle(el).getPropertyValue('--electric-border-color').trim() || '#57c2b8';
    let time = 0;
    let lastFrame = performance.now();

    const render = (now: number) => {
      const dt = (now - lastFrame) / 1000;
      time += dt * speed;
      lastFrame = now;
      if (width === 0) { size(); return; }

      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.scale(dpr, dpr);
      ctx.strokeStyle = color;
      ctx.lineWidth = 1;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      const scale = displacement;
      const left = borderOffset, top = borderOffset;
      const bw = width - 2 * borderOffset, bh = height - 2 * borderOffset;
      const maxR = Math.min(bw, bh) / 2;
      const r = Math.min(borderRadius, maxR);
      const perim = 2 * (bw + bh) + 2 * Math.PI * r;
      const n = Math.max(30, Math.floor(perim / 2));

      ctx.beginPath();
      for (let i = 0; i <= n; i++) {
        const t = i / n;
        const pt = rrPoint(t, left, top, bw, bh, r);
        const xn = octavedNoise(t * 8, 0, time);
        const yn = octavedNoise(t * 8, 1, time);
        const dx = pt.x + xn * scale, dy = pt.y + yn * scale;
        if (i === 0) ctx.moveTo(dx, dy);
        else ctx.lineTo(dx, dy);
      }
      ctx.closePath();
      ctx.stroke();
    };

    const ro = new ResizeObserver(() => size());
    ro.observe(el);

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      render(performance.now());
    } else {
      const loop = (now: number) => {
        render(now);
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('.electric-border').forEach(initElectricBorder);
  }
  if (document.readyState !== 'loading') initAll();
  else document.addEventListener('DOMContentLoaded', initAll);
</script>
