---
---
<header class="menubar">
  <div class="menubar-inner">
    <a class="brand" href="/">Desktop app marketplace</a>
    <nav class="menubar-nav">
      <a href="/#catalog">Catalog</a>
      <a href="#" class="disabled">Submit an app</a>
    </nav>
    <div class="menubar-actions">
      <button class="search-hint" type="button" id="open-cmdk">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" style="width:14px;height:14px;flex:0 0 auto">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>Search apps</span>
        <kbd>&#8984;K</kbd>
      </button>
      <button class="theme-toggle" type="button" id="theme-toggle" aria-label="Toggle light and dark theme">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
      </button>
    </div>
  </div>
</header>
