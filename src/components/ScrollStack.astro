---
// Vanilla port of the React Bits <ScrollStack /> — cards pin & stack as you
// scroll a contained region. Framework-free for the Astro static site.
// Contained-frame tweaks vs the original: the stack stays pinned at the end
// (no "release" that empties the frame), and a caption bar below the frame
// tracks the current card. Progressive enhancement: without JS / under
// reduced-motion the same markup is a plain vertical scroll list.
interface Props {
  class?: string;
  itemDistance?: number;
  itemScale?: number;
  itemStackDistance?: number;
  stackPosition?: string;
  scaleEndPosition?: string;
  baseScale?: number;
  rotationAmount?: number;
  blurAmount?: number;
}
const {
  class: className = '',
  itemDistance = 40,
  itemScale = 0.015,
  // Tight stack offset so every card — including the last — stays inside the
  // contained frame instead of being pushed below it.
  itemStackDistance = 6,
  stackPosition = '4%',
  scaleEndPosition = '3%',
  baseScale = 0.92,
  rotationAmount = 0,
  blurAmount = 1.5,
} = Astro.props;
---
<div class="scroll-stack-wrap">
  <div
    class:list={['scroll-stack-scroller', className]}
    data-item-distance={itemDistance}
    data-item-scale={itemScale}
    data-item-stack-distance={itemStackDistance}
    data-stack-position={stackPosition}
    data-scale-end-position={scaleEndPosition}
    data-base-scale={baseScale}
    data-rotation-amount={rotationAmount}
    data-blur-amount={blurAmount}
  >
    <div class="scroll-stack-inner">
      <slot />
      <div class="scroll-stack-end"></div>
    </div>
  </div>
  <div class="stack-caption" data-stack-caption>
    <div class="stack-caption-text">
      <h4></h4>
      <p></p>
    </div>
    <div class="stack-caption-meta">
      <span class="stack-caption-tag"></span>
      <span class="stack-caption-count"></span>
    </div>
  </div>
</div>

<script>
  import Lenis from 'lenis';

  function initScrollStack(scroller: HTMLElement) {
    if ((scroller as any).__ssInit) return;
    const cards = Array.from(scroller.querySelectorAll<HTMLElement>('.scroll-stack-card'));
    if (!cards.length) return;

    const wrap = scroller.closest('.scroll-stack-wrap') as HTMLElement | null;
    const captionEl = wrap?.querySelector<HTMLElement>('[data-stack-caption]') || null;
    const capTitle = captionEl?.querySelector('h4') || null;
    const capText = captionEl?.querySelector('p') || null;
    const capTag = captionEl?.querySelector('.stack-caption-tag') || null;
    const capCount = captionEl?.querySelector('.stack-caption-count') || null;

    function setCaption(i: number) {
      const card = cards[i];
      if (!card) return;
      if (capTitle) capTitle.textContent = card.dataset.title || '';
      if (capText) capText.textContent = card.dataset.caption || '';
      if (capTag) capTag.textContent = card.dataset.section || '';
      if (capCount) capCount.textContent = `${i + 1} / ${cards.length}`;
    }
    setCaption(0);

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return; // plain vertical list, per-card captions shown via CSS

    (scroller as any).__ssInit = true;
    scroller.classList.add('ss-active');
    if (wrap) wrap.classList.add('ss-on');

    const d = scroller.dataset;
    const itemDistance = parseFloat(d.itemDistance || '40');
    const itemScale = parseFloat(d.itemScale || '0.015');
    const itemStackDistance = parseFloat(d.itemStackDistance || '6');
    const stackPosition = d.stackPosition || '4%';
    const scaleEndPosition = d.scaleEndPosition || '3%';
    const baseScale = parseFloat(d.baseScale || '0.92');
    const rotationAmount = parseFloat(d.rotationAmount || '0');
    const blurAmount = parseFloat(d.blurAmount || '2');

    const inner = scroller.querySelector<HTMLElement>('.scroll-stack-inner')!;
    const lastTransforms = new Map<number, any>();
    let isUpdating = false;
    let activeIndex = -1;
    let lenis: any = null;

    const parsePct = (value: string, h: number) =>
      typeof value === 'string' && value.includes('%') ? (parseFloat(value) / 100) * h : parseFloat(value);
    const offsetTop = (el: HTMLElement) => el.offsetTop;
    const calcProgress = (s: number, a: number, b: number) => (s < a ? 0 : s > b ? 1 : (s - a) / (b - a));

    function update() {
      if (!cards.length || isUpdating) return;
      isUpdating = true;

      const scrollTop = scroller.scrollTop;
      const containerHeight = scroller.clientHeight;
      const stackPositionPx = parsePct(stackPosition, containerHeight);
      const scaleEndPositionPx = parsePct(scaleEndPosition, containerHeight);

      // The card currently on top of the stack (highest one whose pin has begun).
      let topCardIndex = 0;
      for (let j = 0; j < cards.length; j++) {
        const jTop = offsetTop(cards[j]);
        if (scrollTop >= jTop - stackPositionPx - itemStackDistance * j) topCardIndex = j;
      }
      if (topCardIndex !== activeIndex) {
        activeIndex = topCardIndex;
        setCaption(activeIndex);
      }

      cards.forEach((card, i) => {
        if (!card) return;
        const cardTop = offsetTop(card);
        const triggerStart = cardTop - stackPositionPx - itemStackDistance * i;
        const triggerEnd = cardTop - scaleEndPositionPx;
        const pinStart = cardTop - stackPositionPx - itemStackDistance * i;

        const scaleProgress = calcProgress(scrollTop, triggerStart, triggerEnd);
        // Clamp to 1 so front (high-index) cards never scale *up* past full size
        // and overflow the frame — they only ever shrink as they recede.
        const targetScale = Math.min(1, baseScale + i * itemScale);
        const scale = 1 - scaleProgress * (1 - targetScale);
        const rotation = rotationAmount ? i * rotationAmount * scaleProgress : 0;

        let blur = 0;
        if (blurAmount && i < topCardIndex) blur = Math.max(0, (topCardIndex - i) * blurAmount);

        // Contained frame: once pinned, STAY pinned (no release) so the frame
        // never empties out at the end.
        const translateY = scrollTop >= pinStart ? scrollTop - cardTop + stackPositionPx + itemStackDistance * i : 0;

        const nt = {
          translateY: Math.round(translateY * 100) / 100,
          scale: Math.round(scale * 1000) / 1000,
          rotation: Math.round(rotation * 100) / 100,
          blur: Math.round(blur * 100) / 100,
        };
        const lt = lastTransforms.get(i);
        const changed =
          !lt ||
          Math.abs(lt.translateY - nt.translateY) > 0.1 ||
          Math.abs(lt.scale - nt.scale) > 0.001 ||
          Math.abs(lt.rotation - nt.rotation) > 0.1 ||
          Math.abs(lt.blur - nt.blur) > 0.1;
        if (changed) {
          card.style.transform = `translate3d(0, ${nt.translateY}px, 0) scale(${nt.scale}) rotate(${nt.rotation}deg)`;
          card.style.filter = nt.blur > 0 ? `blur(${nt.blur}px)` : '';
          lastTransforms.set(i, nt);
        }
      });

      isUpdating = false;
    }

    cards.forEach((card, i) => {
      if (i < cards.length - 1) card.style.marginBottom = `${itemDistance}px`;
      card.style.willChange = 'transform, filter';
      card.style.transformOrigin = 'top center';
      card.style.backfaceVisibility = 'hidden';
    });

    try {
      lenis = new Lenis({
        wrapper: scroller,
        content: inner,
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 2,
        wheelMultiplier: 1,
        lerp: 0.1,
        syncTouch: true,
        syncTouchLerp: 0.075,
      });
    } catch (e) {
      console.warn('ScrollStack: lenis init failed, using plain list.', e);
      scroller.classList.remove('ss-active');
      if (wrap) wrap.classList.remove('ss-on');
      (scroller as any).__ssInit = false;
      cards.forEach((c) => { c.style.marginBottom = ''; });
      return;
    }
    lenis.on('scroll', update);
    const raf = (time: number) => {
      lenis.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
    scroller.addEventListener('scroll', update, { passive: true });
    update();
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('.scroll-stack-scroller').forEach(initScrollStack);
  }
  if (document.readyState !== 'loading') initAll();
  else document.addEventListener('DOMContentLoaded', initAll);
</script>
